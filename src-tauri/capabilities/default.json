{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Default capabilities for Vox desktop",
    "windows": [
        "main",
        "widget"
    ],
    "permissions": [
        "core:default",
        "autostart:allow-disable",
        "autostart:allow-enable",
        "autostart:allow-is-enabled",
        "updater:default",
        "sql:allow-execute",
        "sql:allow-select",
        "sql:allow-load"
    ]
}
