{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Vox",
    "version": "0.0.1",
    "identifier": "app.vox.desktop",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "macOSPrivateApi": true,
        "windows": [
            {
                "label": "main",
                "title": "",
                "width": 1100,
                "height": 720,
                "minWidth": 860,
                "minHeight": 560,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "titleBarStyle": "Overlay",
                "transparent": false
            },
            {
                "label": "widget",
                "title": "Vox Widget",
                "url": "widget.html",
                "width": 220,
                "height": 64,
                "resizable": false,
                "fullscreen": false,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "visible": true,
                "focus": false,
                "x": -9999,
                "y": -9999
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "minimumSystemVersion": "10.15"
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/imrj05/vox-app/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzRjE0RjNGNDA2NUQ0NzkKUldSNTFHVkFQMC94czJPamdzQmc3WHZTNHd4b0J5bEFzMThVczZLSHJTQ2p4Mzg2VE5sY1ZOZHEK"
        }
    }
}
